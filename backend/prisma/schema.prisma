// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  engineType    = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 會員
model Member {
  member_id    Int       @id @default(autoincrement())
  email        String    @unique // 電子郵件
  password     String    // 密碼
  name         String    // 姓名
  birthday     DateTime? // 生日
  bio          String?   @db.Text // 自介
  blood_type   String?   // 血型
  constellation String?  // 星座
  created_at   DateTime  @default(now()) // 註冊時間
  
  // 關聯：一個會員發表多個瓶子
  bottles      Bottle[]
}

// 漂流瓶
model Bottle {
  bottle_id        Int      @id @default(autoincrement())
  member_id        Int      // 外鍵：指向發表者
  is_anonymous     Boolean  @default(false) // 是否匿名
  content          String   @db.Text // 內容
  created_at       DateTime @default(now()) // 發布時間
  title            String   // 標題
  view_count       Int      @default(0) // 觀看人數
  status           Int      @default(0) // 審核狀態 (0待審, 1通過, 2違規)
  violation_reason String?  // 違規原因

  // 關聯定義
  author           Member   @relation(fields: [member_id], references: [member_id])
  // 關聯：透過「擁有」中間表連接到類別
  categories       BottleCategory[]
}

// 類別表
model Category {
  category_id   Int      @id @default(autoincrement())
  name          String   @unique // 類別名稱
  
  // 關聯
  bottles       BottleCategory[]
}

// 「擁有」中間表 M:N 多對多關係
model BottleCategory {
  bottle_id   Int
  category_id Int

  bottle      Bottle   @relation(fields: [bottle_id], references: [bottle_id])
  category    Category @relation(fields: [category_id], references: [category_id])

  @@id([bottle_id, category_id]) // 複合主鍵，確保同一個瓶子不會重複加入同一個類別
}
